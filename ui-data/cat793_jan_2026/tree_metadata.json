  "formulas": [
    {
      "formula_id": "improved_payload",
      "label": "Improved Payload",
      "expression": "baseline_payload * (1 + payload_delta_pct)",
      "output_unit": "tonnes/cycle",
      "description": "Applies the payload improvement assumption to baseline payload."
    },
    {
      "formula_id": "cycle_seconds_sum",
      "label": "Cycle Seconds",
      "expression": "sum(selected cycle component seconds_per_cycle)",
      "output_unit": "seconds/cycle",
      "description": "Reconstructs cycle time from validated component statuses."
    },
    {
      "formula_id": "seconds_to_minutes",
      "label": "Seconds To Minutes",
      "expression": "seconds / 60",
      "output_unit": "minutes",
      "description": "Converts seconds to minutes."
    },
    {
      "formula_id": "cycle_seconds_removed",
      "label": "Cycle Seconds Removed",
      "expression": "component_seconds * component_reduction_pct",
      "output_unit": "seconds/cycle",
      "description": "Calculates seconds removed from a selected cycle component."
    },
    {
      "formula_id": "improved_cycle_minutes",
      "label": "Improved Cycle Minutes",
      "expression": "(baseline_cycle_seconds - cycle_seconds_removed) / 60",
      "output_unit": "minutes/cycle",
      "description": "Calculates improved cycle time."
    },
    {
      "formula_id": "improved_operating_hours",
      "label": "Improved Operating Hours",
      "expression": "baseline_operating_hours + required_hours * availability_delta_points + operational_standby_hours * standby_reduction_pct + operating_delay_hours * delay_reduction_pct",
      "output_unit": "hours/month",
      "description": "Calculates operating hours after availability, standby or delay assumptions."
    },
    {
      "formula_id": "production_rate_tph",
      "label": "Production Rate",
      "expression": "payload / (cycle_minutes / 60)",
      "output_unit": "tonnes/hour",
      "description": "Calculates truck production rate."
    },
    {
      "formula_id": "modelled_tonnes",
      "label": "Modelled Tonnes",
      "expression": "rate_tph * operating_hours",
      "output_unit": "tonnes/month",
      "description": "Calculates modelled material movement."
    },
    {
      "formula_id": "tmm_uplift",
      "label": "TMM Uplift",
      "expression": "improved_modelled_tonnes - baseline_modelled_tonnes",
      "output_unit": "tonnes/month",
      "description": "Calculates monthly total material movement uplift."
    },
    {
      "formula_id": "annualize_monthly",
      "label": "Annualize Monthly Value",
      "expression": "monthly_value * 12",
      "output_unit": "value/year",
      "description": "Simple annualization of a one-month result."
    },
    {
      "formula_id": "baseline_tonnes_per_truck_month",
      "label": "Baseline Tonnes Per Truck Month",
      "expression": "baseline_modelled_tonnes / cycle_truck_count",
      "output_unit": "tonnes/truck/month",
      "description": "Calculates average baseline modelled tonnes per truck."
    },
    {
      "formula_id": "truck_equivalent",
      "label": "Truck Equivalent",
      "expression": "tmm_uplift_tonnes / baseline_tonnes_per_truck_month",
      "output_unit": "trucks",
      "description": "Converts monthly uplift into equivalent average baseline trucks."
    },
    {
      "formula_id": "direct_crusher_uplift",
      "label": "Direct Crusher Uplift",
      "expression": "tmm_uplift_tonnes * direct_crusher_ratio",
      "output_unit": "tonnes/month",
      "description": "Converts TMM uplift into estimated direct crusher uplift."
    }
  ]
}
